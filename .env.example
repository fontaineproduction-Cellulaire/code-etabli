# Base de données Railway PostgreSQL
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require"
DIRECT_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require"

# Clé API OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
Documenter variables Perplexity et CCQ URLs dans .env.example# Clé API Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Clé API Perplexity — https://www.perplexity.ai/settings/api
# Utilisée comme fallback quand la source locale est insuffisante
# Recherche sur ccq.com, rbq.gouv.qc.ca, nrc-cnrc.gc.ca, etc.
PERPLEXITY_API_KEY="pplx-..."

# Mode admin : mettre "true" pour accéder au panneau d'upload
ADMIN_MODE="false"
NEXT_PUBLIC_ADMIN_MODE="false"

# Nom de l'application
NEXT_PUBLIC_APP_NAME="L'Établi — Code & Normes"

# URLs des parties du CCQ découpé (pour indexation via /api/seed sans upload)
# Héberger les PDFs sur un service public (ex: GitHub Releases, Google Drive public, etc.)
# Chaque partie doit faire moins de 50 Mo et être accessible publiquement
CCQ_PDF_URL_PART1=""
CCQ_PDF_URL_PART2=""
CCQ_PDF_URL_PART3=""

# Optionnel: Vercel Blob pour le stockage des PDFs uploadés via le panneau admin
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
